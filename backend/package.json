{
  "name": "abacus-backend",
  "license": "ISC",
  "scripts": {
    "dev": "nodemon",
    "zip": "cp package.json dist/ && cd dist && zip -r backend .",
    "build": "tsc",
    "start": "node server.js"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts",
    "exec": "NODE_ENV=development ts-node --files src/server.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.438.0",
    "@aws-sdk/client-lambda": "^3.438.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "archiver": "^6.0.1",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.2.0",
    "morgan": "^1.10.0",
    "redis": "^4.6.10",
    "socket.io": "^4.6.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-fileupload": "^1.4.0",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.8.9",
    "@types/redis": "^4.0.11",
    "@types/socket.io": "^3.0.2",
    "@types/socket.io-redis": "^3.0.0",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/uuid": "^9.0.6",
    "nodemon": "^3.0.1",
    "openapi-types": "^12.1.3",
    "ts-node": "10.9.1",
    "typescript": "^5.2.2"
  }
}
